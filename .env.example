# 统一环境变量（本项目默认只使用 Grok/xAI）

# 建议先开启 debug，便于排查“输入无反应”卡在哪里
DEBUG=1

API_KEY=
# 可选：Agent 里优先读取 OPENAI_API_KEY，为空时回退到 API_KEY
OPENAI_API_KEY=
MODEL=grok-4-1-fast
BASE_URL=https://api.x.ai/v1
PROXY_URL=http://127.0.0.1:7897
THREAD_ID=42

TEMPERATURE=0.7
TIMEOUT_MS=60000

# Tavily（Agent 搜索工具需要）
TAVILY_API_KEY=

# 双 AI 链式对话
DUAL_AI_TURNS=2
AI_A_NAME=分析师A
AI_A_ROLE=善于拆解问题并提出方案
AI_B_NAME=批判者B
AI_B_ROLE=善于质疑假设并补充风险

# LangSmith（链路追踪）
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=my-langchain-chatbot

