# 统一环境变量（本项目默认只使用 Grok/xAI）

# 建议先开启 debug，便于排查“输入无反应”卡在哪里
DEBUG=1

API_KEY=
# 可选：Agent 里优先读取 OPENAI_API_KEY，为空时回退到 API_KEY
OPENAI_API_KEY=
MODEL=grok-4-1-fast
BASE_URL=https://api.x.ai/v1

TEMPERATURE=0.7
TIMEOUT_MS=60000

# Tavily（Agent 搜索工具需要）
TAVILY_API_KEY=

# LangSmith（链路追踪）
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=my-langchain-chatbot

